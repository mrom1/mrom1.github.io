[{"data":1,"prerenderedAt":468},["ShallowReactive",2],{"article-/articles/new-test-article-4":3},{"id":4,"title":5,"body":6,"createdAt":453,"description":454,"extension":455,"meta":456,"navigation":457,"path":458,"readingTime":459,"seo":460,"stem":461,"tags":462,"__hash__":467},"articles/articles/new-test-article-4.md","Getting Started with Git and Version Control",{"type":7,"value":8,"toc":445},"minimark",[9,14,18,22,25,54,58,61,221,225,228,380,387,400,435,438,441],[10,11,13],"h2",{"id":12},"introduction-to-git-and-version-control","Introduction to Git and Version Control",[15,16,17],"p",{},"Git is a powerful, distributed version control system that helps developers track changes in source code during software development. It's designed for coordinating work among programmers, but it can be used to track changes in any set of files.",[10,19,21],{"id":20},"why-use-version-control","Why Use Version Control?",[15,23,24],{},"Version control systems (VCS) are essential for several reasons:",[26,27,28,36,42,48],"ul",{},[29,30,31,35],"li",{},[32,33,34],"strong",{},"Collaboration",": Multiple developers can work on the same project simultaneously without overwriting each other's changes.",[29,37,38,41],{},[32,39,40],{},"History Tracking",": Every change made to the codebase is recorded, allowing you to revert to previous versions if needed.",[29,43,44,47],{},[32,45,46],{},"Branching and Merging",": Create separate lines of development for new features or bug fixes, then integrate them back into the main codebase.",[29,49,50,53],{},[32,51,52],{},"Backup and Recovery",": Your code history is stored, providing a safety net against data loss.",[10,55,57],{"id":56},"basic-git-commands","Basic Git Commands",[15,59,60],{},"Here are some fundamental Git commands you'll use regularly:",[62,63,64,81],"table",{},[65,66,67],"thead",{},[68,69,70,75,78],"tr",{},[71,72,74],"th",{"align":73},"left","Command",[71,76,77],{"align":73},"Description",[71,79,80],{"align":73},"Example Usage",[82,83,84,101,116,132,147,161,176,191,206],"tbody",{},[68,85,86,93,96],{},[87,88,89],"td",{"align":73},[90,91,92],"code",{},"git init",[87,94,95],{"align":73},"Initializes a new Git repository",[87,97,98],{"align":73},[90,99,100],{},"git init my-project",[68,102,103,108,111],{},[87,104,105],{"align":73},[90,106,107],{},"git clone",[87,109,110],{"align":73},"Creates a copy of an existing remote repository",[87,112,113],{"align":73},[90,114,115],{},"git clone https://github.com/user/repo.git",[68,117,118,123,126],{},[87,119,120],{"align":73},[90,121,122],{},"git add",[87,124,125],{"align":73},"Stages changes for the next commit",[87,127,128,131],{"align":73},[90,129,130],{},"git add ."," (add all changes)",[68,133,134,139,142],{},[87,135,136],{"align":73},[90,137,138],{},"git commit",[87,140,141],{"align":73},"Saves staged changes to the repository",[87,143,144],{"align":73},[90,145,146],{},"git commit -m \"Initial commit\"",[68,148,149,154,157],{},[87,150,151],{"align":73},[90,152,153],{},"git status",[87,155,156],{"align":73},"Shows the working tree status",[87,158,159],{"align":73},[90,160,153],{},[68,162,163,168,171],{},[87,164,165],{"align":73},[90,166,167],{},"git push",[87,169,170],{"align":73},"Uploads local commits to a remote repository",[87,172,173],{"align":73},[90,174,175],{},"git push origin main",[68,177,178,183,186],{},[87,179,180],{"align":73},[90,181,182],{},"git pull",[87,184,185],{"align":73},"Fetches and integrates changes from a remote",[87,187,188],{"align":73},[90,189,190],{},"git pull origin main",[68,192,193,198,201],{},[87,194,195],{"align":73},[90,196,197],{},"git branch",[87,199,200],{"align":73},"Lists, creates, or deletes branches",[87,202,203],{"align":73},[90,204,205],{},"git branch feature/new-feature",[68,207,208,213,216],{},[87,209,210],{"align":73},[90,211,212],{},"git checkout",[87,214,215],{"align":73},"Switches branches or restores working tree files",[87,217,218],{"align":73},[90,219,220],{},"git checkout dev",[10,222,224],{"id":223},"git-workflow-example","Git Workflow Example",[15,226,227],{},"Let's walk through a common Git workflow for adding a new feature:",[229,230,231,272,295,301,321,344,366],"ol",{},[29,232,233,236,237],{},[32,234,235],{},"Clone the repository",":",[238,239,244],"pre",{"className":240,"code":241,"language":242,"meta":243,"style":243},"language-bash shiki shiki-themes github-dark","git clone https://github.com/your-username/your-repo.git\ncd your-repo\n","bash","",[90,245,246,262],{"__ignoreMap":243},[247,248,251,255,259],"span",{"class":249,"line":250},"line",1,[247,252,254],{"class":253},"svObZ","git",[247,256,258],{"class":257},"sU2Wk"," clone",[247,260,261],{"class":257}," https://github.com/your-username/your-repo.git\n",[247,263,265,269],{"class":249,"line":264},2,[247,266,268],{"class":267},"sDLfK","cd",[247,270,271],{"class":257}," your-repo\n",[29,273,274,236,277],{},[32,275,276],{},"Create a new branch for your feature",[238,278,280],{"className":240,"code":279,"language":242,"meta":243,"style":243},"git checkout -b feature/my-new-feature\n",[90,281,282],{"__ignoreMap":243},[247,283,284,286,289,292],{"class":249,"line":250},[247,285,254],{"class":253},[247,287,288],{"class":257}," checkout",[247,290,291],{"class":267}," -b",[247,293,294],{"class":257}," feature/my-new-feature\n",[29,296,297,300],{},[32,298,299],{},"Make changes to your files",".",[29,302,303,236,306],{},[32,304,305],{},"Stage your changes",[238,307,309],{"className":240,"code":308,"language":242,"meta":243,"style":243},"git add .\n",[90,310,311],{"__ignoreMap":243},[247,312,313,315,318],{"class":249,"line":250},[247,314,254],{"class":253},[247,316,317],{"class":257}," add",[247,319,320],{"class":257}," .\n",[29,322,323,236,326],{},[32,324,325],{},"Commit your changes",[238,327,329],{"className":240,"code":328,"language":242,"meta":243,"style":243},"git commit -m \"feat: Implement my new feature\"\n",[90,330,331],{"__ignoreMap":243},[247,332,333,335,338,341],{"class":249,"line":250},[247,334,254],{"class":253},[247,336,337],{"class":257}," commit",[247,339,340],{"class":267}," -m",[247,342,343],{"class":257}," \"feat: Implement my new feature\"\n",[29,345,346,236,349],{},[32,347,348],{},"Push your new branch to the remote repository",[238,350,352],{"className":240,"code":351,"language":242,"meta":243,"style":243},"git push origin feature/my-new-feature\n",[90,353,354],{"__ignoreMap":243},[247,355,356,358,361,364],{"class":249,"line":250},[247,357,254],{"class":253},[247,359,360],{"class":257}," push",[247,362,363],{"class":257}," origin",[247,365,294],{"class":257},[29,367,368,371,372,375,376,379],{},[32,369,370],{},"Create a Pull Request (PR)"," on GitHub/GitLab/Bitbucket to merge your feature branch into the ",[90,373,374],{},"main"," or ",[90,377,378],{},"develop"," branch.",[10,381,383,384],{"id":382},"understanding-gitignore","Understanding ",[90,385,386],{},".gitignore",[15,388,389,390,392,393,375,396,399],{},"The ",[90,391,386],{}," file specifies intentionally untracked files that Git should ignore. This is useful for keeping sensitive information (like API keys) or generated files (like ",[90,394,395],{},"node_modules",[90,397,398],{},"build/"," directories) out of your repository.",[238,401,405],{"className":402,"code":403,"language":404,"meta":243,"style":243},"language-console shiki shiki-themes github-dark","# Example .gitignore file\nnode_modules/\n.env\nbuild/\n*.log\n","console",[90,406,407,412,417,423,429],{"__ignoreMap":243},[247,408,409],{"class":249,"line":250},[247,410,411],{},"# Example .gitignore file\n",[247,413,414],{"class":249,"line":264},[247,415,416],{},"node_modules/\n",[247,418,420],{"class":249,"line":419},3,[247,421,422],{},".env\n",[247,424,426],{"class":249,"line":425},4,[247,427,428],{},"build/\n",[247,430,432],{"class":249,"line":431},5,[247,433,434],{},"*.log\n",[436,437],"hr",{},[15,439,440],{},"Git is an indispensable tool for modern software development. Mastering its basic commands and understanding common workflows will significantly improve your productivity and collaboration skills.",[442,443,444],"style",{},"html .default .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html .shiki span {color: var(--shiki-default);background: var(--shiki-default-bg);font-style: var(--shiki-default-font-style);font-weight: var(--shiki-default-font-weight);text-decoration: var(--shiki-default-text-decoration);}html pre.shiki code .svObZ, html code.shiki .svObZ{--shiki-default:#B392F0}html pre.shiki code .sU2Wk, html code.shiki .sU2Wk{--shiki-default:#9ECBFF}html pre.shiki code .sDLfK, html code.shiki .sDLfK{--shiki-default:#79B8FF}",{"title":243,"searchDepth":264,"depth":264,"links":446},[447,448,449,450,451],{"id":12,"depth":264,"text":13},{"id":20,"depth":264,"text":21},{"id":56,"depth":264,"text":57},{"id":223,"depth":264,"text":224},{"id":382,"depth":264,"text":452},"Understanding .gitignore","2021-09-01","A beginner-friendly guide to understanding Git, basic commands, and essential version control concepts for developers.","md",{},true,"/articles/new-test-article-4",null,{"title":5,"description":454},"articles/new-test-article-4",[254,463,464,465,466],"version-control","development","tutorial","basics","XPQcrjGmb_HGiWNGTxIhUZ_PruIlvpDEbvnTMhC44LQ",1773168900310]