[{"data":1,"prerenderedAt":708},["ShallowReactive",2],{"article-/articles/new-test-article-8":3},{"id":4,"title":5,"body":6,"createdAt":694,"description":695,"extension":696,"meta":697,"navigation":274,"path":698,"readingTime":699,"seo":700,"stem":701,"tags":702,"__hash__":707},"articles/articles/new-test-article-8.md","Introduction to Docker for Developers",{"type":7,"value":8,"toc":678},"minimark",[9,14,18,22,25,30,59,63,208,212,215,222,466,472,578,582,606,610,631,638,642,668,671,674],[10,11,13],"h2",{"id":12},"docker-essentials-for-developers","Docker Essentials for Developers",[15,16,17],"p",{},"Docker has revolutionized how developers build, ship, and run applications. It provides a way to package applications into isolated environments called containers, ensuring consistency across different development, testing, and production environments.",[10,19,21],{"id":20},"what-is-docker","What is Docker?",[15,23,24],{},"Docker is a platform that uses OS-level virtualization to deliver software in packages called containers. Containers are isolated from one another and bundle their own software, libraries, and configuration files; they can communicate with each other through well-defined channels.",[26,27,29],"h3",{"id":28},"key-concepts","Key Concepts",[31,32,33,41,47,53],"ul",{},[34,35,36,40],"li",{},[37,38,39],"strong",{},"Image",": A read-only template with instructions for creating a Docker container.",[34,42,43,46],{},[37,44,45],{},"Container",": A runnable instance of a Docker image.",[34,48,49,52],{},[37,50,51],{},"Dockerfile",": A script that contains instructions for Docker to build an image.",[34,54,55,58],{},[37,56,57],{},"Docker Hub",": A cloud-based registry service for sharing and managing Docker images.",[10,60,62],{"id":61},"basic-docker-commands","Basic Docker Commands",[64,65,66,83],"table",{},[67,68,69],"thead",{},[70,71,72,77,80],"tr",{},[73,74,76],"th",{"align":75},"left","Command",[73,78,79],{"align":75},"Description",[73,81,82],{"align":75},"Example Usage",[84,85,86,103,118,134,149,164,179,194],"tbody",{},[70,87,88,95,98],{},[89,90,91],"td",{"align":75},[92,93,94],"code",{},"docker build",[89,96,97],{"align":75},"Builds an image from a Dockerfile",[89,99,100],{"align":75},[92,101,102],{},"docker build -t my-app .",[70,104,105,110,113],{},[89,106,107],{"align":75},[92,108,109],{},"docker run",[89,111,112],{"align":75},"Runs a command in a new container",[89,114,115],{"align":75},[92,116,117],{},"docker run -p 80:80 my-app",[70,119,120,125,128],{},[89,121,122],{"align":75},[92,123,124],{},"docker ps",[89,126,127],{"align":75},"Lists running containers",[89,129,130,133],{"align":75},[92,131,132],{},"docker ps -a"," (all containers)",[70,135,136,141,144],{},[89,137,138],{"align":75},[92,139,140],{},"docker stop",[89,142,143],{"align":75},"Stops one or more running containers",[89,145,146],{"align":75},[92,147,148],{},"docker stop my-container",[70,150,151,156,159],{},[89,152,153],{"align":75},[92,154,155],{},"docker rm",[89,157,158],{"align":75},"Removes one or more containers",[89,160,161],{"align":75},[92,162,163],{},"docker rm my-container",[70,165,166,171,174],{},[89,167,168],{"align":75},[92,169,170],{},"docker rmi",[89,172,173],{"align":75},"Removes one or more images",[89,175,176],{"align":75},[92,177,178],{},"docker rmi my-app",[70,180,181,186,189],{},[89,182,183],{"align":75},[92,184,185],{},"docker pull",[89,187,188],{"align":75},"Pulls an image or a repository from a registry",[89,190,191],{"align":75},[92,192,193],{},"docker pull nginx:latest",[70,195,196,201,204],{},[89,197,198],{"align":75},[92,199,200],{},"docker login",[89,202,203],{"align":75},"Log in to a Docker registry",[89,205,206],{"align":75},[92,207,200],{},[10,209,211],{"id":210},"dockerizing-a-simple-nodejs-application","Dockerizing a Simple Node.js Application",[15,213,214],{},"Let's containerize a basic Node.js \"Hello World\" application.",[26,216,218,219],{"id":217},"_1-create-appjs","1. Create ",[92,220,221],{},"app.js",[223,224,