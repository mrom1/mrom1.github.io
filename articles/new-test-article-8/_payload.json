meta":228,"style":228},"language-dockerfile shiki shiki-themes github-dark","# Use an official Node.js runtime as a parent image\nFROM node:18-alpine\n\n# Set the working directory in the container\nWORKDIR /app\n\n# Copy package.json and package-lock.json to the working directory\nCOPY package*.json ./\n\n# Install any dependencies\nRUN npm install\n\n# Copy the rest of the application code to the working directory\nCOPY . .\n\n# Expose the port the app runs on\nEXPOSE 3000\n\n# Define the command to run the application\nCMD [\"node\", \"app.js\"]\n","dockerfile",[92,478,479,484,489,493,498,503,507,512,517,521,526,531,535,540,545,549,555,561,566,572],{"__ignoreMap":228},[232,480,481],{"class":234,"line":235},[232,482,483],{},"# Use an official Node.js runtime as a parent image\n",[232,485,486],{"class":234,"line":242},[232,487,488],{},"FROM node:18-alpine\n",[232,490,491],{"class":234,"line":271},[232,492,275],{"emptyLinePlaceholder":274},[232,494,495],{"class":234,"line":278},[232,496,497],{},"# Set the working directory in the container\n",[232,499,500],{"class":234,"line":294},[232,501,502],{},"WORKDIR /app\n",[232,504,505],{"class":234,"line":309},[232,506,275],{"emptyLinePlaceholder":274},[232,508,509],{"class":234,"line":314},[232,510,511],{},"# Copy package.json and package-lock.json to the working directory\n",[232,513,514],{"class":234,"line":352},[232,515,516],{},"COPY package*.json ./\n",[232,518,519],{"class":234,"line":366},[232,520,275],{"emptyLinePlaceholder":274},[232,522,523],{"class":234,"line":387},[232,524,525],{},"# Install any dependencies\n",[232,527,528],{"class":234,"line":408},[232,529,530],{},"RUN npm install\n",[232,532,533],{"class":234,"line":414},[232,534,275],{"emptyLinePlaceholder":274},[232,536,537],{"class":234,"line":419},[232,538,539],{},"# Copy the rest of the application code to the working directory\n",[232,541,542],{"class":234,"line":435},[232,543,544],{},"COPY . .\n",[232,546,547],{"class":234,"line":463},[232,548,275],{"e