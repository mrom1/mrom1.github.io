alic*",[41,58,59],{},"_italic_",[50,61,62],{},[36,63,64],{},"Bold and Italic Text",": Combine them. For example, ",[41,67,68],{},"***bold and italic***",".",[15,71,72,73,76,77,80],{},"Here's an example sentence: This is some ",[36,74,75],{},"important"," text and this is ",[50,78,79],{},"less important"," text.",[26,82,84],{"id":83},"section-12-headers-and-structure","Section 1.2: Headers and Structure",[15,86,87],{},"Headers are crucial for organizing content. Markdown supports six levels of headings.",[89,90,92],"h4",{"id":91},"subsection-121-heading-levels","Subsection 1.2.1: Heading Levels",[94,95,96,102,107,112,117,122],"ul",{},[97,98,99],"li",{},[41,100,101],{},"# Heading 1",[97,103,104],{},[41,105,106],{},"## Heading 2",[97,108,109],{},[41,110,111],{},"### Heading 3",[97,113,114],{},[41,115,116],{},"#### Heading 4",[97,118,119],{},[41,120,121],{},"##### Heading 5",[97,123,124],{},[41,125,126],{},"###### Heading 6",[15,128,129],{},"The structure of this document itself is an example of nested headings.",[10,131,133],{"id":132},"chapter-2-lists-and-their-variations","Chapter 2: Lists and Their Variations",[15,135,136],{},"Lists are fundamental for presenting information in an organized manner. Markdown supports ordered and unordered lists.",[26,138,140],{"id":139},"section-21-unordered-lists","Section 2.1: Unordered Lists",[94,142,143,146,162],{},[97,144,145],{},"Item One",[97,147,148,149],{},"Item Two\n",[94,150,151,154],{},[97,152,153],{},"Sub-item 2.1",[97,155,156,157],{},"Sub-item 2.2\n",[94,158,159],{},[97,160,161],{},"Sub-sub-item 2.2.1",[97,163,164],{},"Item Three",[26,166,168],{"id":167},"section-22-ordered-lists","Section 2.2: Ordered Lists",[170,171,172,175,186],"ol",{},[97,173,174],{},"First item",[97,176,177,178],{},"Second item\n",[170,179,180,183],{},[97,181,182],{},"Nested ordered item A",[97,184,185],{},"Nested ordered item B",[97,187,188],{},"Third item",[26,190,192],{"id":191},"section-23-task-lists","Section 2.3: Task Lists",[94,194,197,207,2